// Prisma data model for recipes and ingredients.
generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "sqlite"
}

model Recipe {
  id              Int           @id @default(autoincrement())
  title           String
  description     String?
  stepsMarkdown   String
  language        RecipeLanguage @default(en)
  visibility      RecipeVisibility @default(public)
  createdByUserId Int        @map("created_by_user_id")
  createdByUser  User        @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  ingredients     Ingredient[]
  images          RecipeImage[]
  sourceDocuments RecipeSourceDocument[]
  familyLinks     RecipeFamilyLink[]
}

model Ingredient {
  id        Int      @id @default(autoincrement())
  recipeId  Int
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  name      String
  qtyNum    Int
  qtyDen    Int      @default(1)
  unit      String
  notes     String?
  position  Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recipeId, position])
}

model User {
  id           Int      @id @default(autoincrement())
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  email        String   @unique
  username     String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  recipes      Recipe[]
  importSessions ImportSession[]
  recipeSourceDocuments RecipeSourceDocument[]
  createdFamilies Family[] @relation("FamilyCreator")
  familyMemberships FamilyMembership[]
  createdFamilyInvites FamilyInvite[] @relation("FamilyInviteCreator")
  consumedFamilyInvites FamilyInvite[] @relation("FamilyInviteConsumer")
  familyInviteDecisions FamilyInviteDecision[]
  initiatedFamilyDeletionRequests FamilyDeletionRequest[] @relation("FamilyDeletionInitiator")
  familyDeletionVotes FamilyDeletionVote[]
  familyAuditEvents FamilyAuditEvent[] @relation("FamilyAuditActor")
  metricEvents MetricEvent[] @relation("MetricActor")

  @@map("users")
}

enum ImportSessionStatus {
  PARSED
  CONFIRMED
  EXPIRED
  FAILED
}

model ImportSession {
  id        String              @id @default(cuid())
  userId    Int                 @map("user_id")
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    ImportSessionStatus @default(PARSED)
  draftJson String              @map("draft_json")
  warningsJson String?          @map("warnings_json")
  sourceRefsJson String?        @map("source_refs_json")
  metadataJson String?          @map("metadata_json")
  providerName String?          @map("provider_name")
  providerModel String?         @map("provider_model")
  promptVersion String?         @map("prompt_version")
  expiresAt DateTime            @map("expires_at")
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")
  sourceDocuments RecipeSourceDocument[]

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model RecipeSourceDocument {
  id               Int      @id @default(autoincrement())
  recipeId         Int?     @map("recipe_id")
  recipe           Recipe?  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  importSessionId  String?  @map("import_session_id")
  importSession    ImportSession? @relation(fields: [importSessionId], references: [id], onDelete: Cascade)
  uploadedByUserId Int      @map("uploaded_by_user_id")
  uploadedByUser   User     @relation(fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  originalFilename String   @map("original_filename")
  mimeType         String   @map("mime_type")
  sizeBytes        Int      @map("size_bytes")
  storageKey       String   @map("storage_key")
  sourceType       String   @map("source_type")
  metadataJson     String?  @map("metadata_json")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([recipeId, createdAt])
  @@index([importSessionId, createdAt])
  @@index([uploadedByUserId, createdAt])
}

model RecipeImage {
  id               Int      @id @default(autoincrement())
  recipeId         Int
  recipe           Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  storageKey       String
  thumbnailKey     String
  originalFilename String
  mimeType         String
  sizeBytes        Int
  width            Int
  height           Int
  position         Int
  isPrimary        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([recipeId, position])
  @@index([recipeId, isPrimary])
}

enum FamilyRole {
  admin
  member
}

enum FamilyInviteDecisionStatus {
  pending
  declined
  accepted
}

enum FamilyDeletionRequestStatus {
  active
  approved
  denied
  cancelled
  expired
}

enum FamilyDeletionVoteValue {
  approve
  deny
}

enum RecipeVisibility {
  public
  private
  family
}

enum RecipeLanguage {
  en
  es
}

model Family {
  id              Int      @id @default(autoincrement())
  name            String
  description     String?
  pictureStorageKey String? @map("picture_storage_key")
  deletionCooldownUntil DateTime? @map("deletion_cooldown_until")
  createdByUserId Int      @map("created_by_user_id")
  createdByUser   User     @relation("FamilyCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  memberships     FamilyMembership[]
  invites         FamilyInvite[]
  deletionRequests FamilyDeletionRequest[]
  recipeLinks     RecipeFamilyLink[]
  auditEvents     FamilyAuditEvent[]
  metricEvents    MetricEvent[]

  @@index([createdByUserId])
}

model RecipeFamilyLink {
  id        Int      @id @default(autoincrement())
  recipeId  Int      @map("recipe_id")
  familyId  Int      @map("family_id")
  createdAt DateTime @default(now()) @map("created_at")

  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  family    Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([recipeId, familyId])
  @@index([familyId])
}

model FamilyMembership {
  id        Int        @id @default(autoincrement())
  familyId  Int        @map("family_id")
  userId    Int        @map("user_id")
  role      FamilyRole
  joinedAt  DateTime   @default(now()) @map("joined_at")

  family    Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
  @@index([userId])
  @@index([familyId, role])
}

model FamilyInvite {
  id               Int      @id @default(autoincrement())
  familyId         Int      @map("family_id")
  tokenHash        String   @unique @map("token_hash")
  createdByUserId  Int      @map("created_by_user_id")
  expiresAt        DateTime @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  consumedAt       DateTime? @map("consumed_at")
  consumedByUserId Int?     @map("consumed_by_user_id")
  maxUses          Int      @default(1) @map("max_uses")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  family           Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  createdByUser    User     @relation("FamilyInviteCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  consumedByUser   User?    @relation("FamilyInviteConsumer", fields: [consumedByUserId], references: [id], onDelete: SetNull)
  decisions        FamilyInviteDecision[]
  metricEvents     MetricEvent[]
  auditEvents      FamilyAuditEvent[]

  @@index([familyId])
  @@index([familyId, expiresAt])
}

model FamilyInviteDecision {
  id            Int                        @id @default(autoincrement())
  inviteId      Int                        @map("invite_id")
  userId        Int                        @map("user_id")
  status        FamilyInviteDecisionStatus @default(pending)
  firstOpenedAt DateTime                   @default(now()) @map("first_opened_at")
  lastOpenedAt  DateTime                   @default(now()) @map("last_opened_at")
  decidedAt     DateTime?                  @map("decided_at")
  createdAt     DateTime                   @default(now()) @map("created_at")
  updatedAt     DateTime                   @updatedAt @map("updated_at")

  invite        FamilyInvite               @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  user          User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([inviteId, userId])
  @@index([userId, status])
}

model FamilyDeletionRequest {
  id                      Int                         @id @default(autoincrement())
  familyId                Int                         @map("family_id")
  initiatedByUserId       Int                         @map("initiated_by_user_id")
  status                  FamilyDeletionRequestStatus @default(active)
  eligibleAdminCount      Int                         @map("eligible_admin_count")
  requiredApprovals       Int                         @map("required_approvals")
  eligibleAdminUserIdsJson String                     @map("eligible_admin_user_ids_json")
  approveCount            Int                         @default(0) @map("approve_count")
  denyCount               Int                         @default(0) @map("deny_count")
  expiresAt               DateTime                    @map("expires_at")
  resolvedAt              DateTime?                   @map("resolved_at")
  resolveReason           String?                     @map("resolve_reason")
  createdAt               DateTime                    @default(now()) @map("created_at")
  updatedAt               DateTime                    @updatedAt @map("updated_at")

  family                  Family                      @relation(fields: [familyId], references: [id], onDelete: Cascade)
  initiatedByUser         User                        @relation("FamilyDeletionInitiator", fields: [initiatedByUserId], references: [id], onDelete: Restrict)
  votes                   FamilyDeletionVote[]

  @@index([familyId, status])
  @@index([status, expiresAt])
}

model FamilyDeletionVote {
  id                Int                    @id @default(autoincrement())
  deletionRequestId Int                    @map("deletion_request_id")
  userId            Int                    @map("user_id")
  vote              FamilyDeletionVoteValue
  votedAt           DateTime               @default(now()) @map("voted_at")
  createdAt         DateTime               @default(now()) @map("created_at")

  deletionRequest   FamilyDeletionRequest  @relation(fields: [deletionRequestId], references: [id], onDelete: Cascade)
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([deletionRequestId, userId])
  @@index([userId])
}

model FamilyAuditEvent {
  id           Int      @id @default(autoincrement())
  eventType    String   @map("event_type")
  requestId    String   @map("request_id")
  actorUserId  Int?     @map("actor_user_id")
  familyId     Int?     @map("family_id")
  targetUserId Int?     @map("target_user_id")
  inviteId     Int?     @map("invite_id")
  oldRole      FamilyRole? @map("old_role")
  newRole      FamilyRole? @map("new_role")
  metadataJson String?  @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")

  actorUser    User?    @relation("FamilyAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  family       Family?  @relation(fields: [familyId], references: [id], onDelete: SetNull)
  invite       FamilyInvite? @relation(fields: [inviteId], references: [id], onDelete: SetNull)

  @@index([familyId, createdAt])
  @@index([eventType, createdAt])
}

model MetricEvent {
  id             Int      @id @default(autoincrement())
  metricName     String   @map("metric_name")
  requestId      String   @map("request_id")
  actorUserId    Int?     @map("actor_user_id")
  familyId       Int?     @map("family_id")
  inviteId       Int?     @map("invite_id")
  statusCode     Int?     @map("status_code")
  metadataJson   String?  @map("metadata_json")
  createdAt      DateTime @default(now()) @map("created_at")

  actorUser      User?    @relation("MetricActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  family         Family?  @relation(fields: [familyId], references: [id], onDelete: SetNull)
  invite         FamilyInvite? @relation(fields: [inviteId], references: [id], onDelete: SetNull)

  @@index([metricName, createdAt])
  @@index([createdAt])
}
